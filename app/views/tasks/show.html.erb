<h1>Your Task</h1>
<h2><%= @task.title %></h2>
<p><%= @task.details %></p>
<p><%= @task.completed %></p>

<%= link_to "Delete",
task_path(@task),
data: {turbo_method: :delete, turbo_confirm: "Are you sure?"}
%>
<%= link_to "Back to your tasks", tasks_path %>

<%= link_to "Do you want to modifie something? Click here", edit_task_path(@task) %>
