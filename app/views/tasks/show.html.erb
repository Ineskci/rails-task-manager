<div class="container mt-5">
  <h1 class="text-white">Your Task</h1>
  <h2 class="text-white"><%= @task.title %></h2>
<p class="text-white"><%= @task.details %></p>  <p class="text-white"><%= @task.completed %></p>

  <%# Bouton Delete — rouge néon %>
  <%= link_to "Delete", task_path(@task),
    data: {turbo_method: :delete, turbo_confirm: "Are you sure?"},
    class: "btn text-decoration-none",
    style: "color: white; background-color: #ff0000; box-shadow: 0 0 10px #ff0000, 0 0 20px #ff0000;"
  %>

  <%# Lien Back — bouton noir néon %>
<%= link_to "Back to your tasks", tasks_path,
  class: "btn text-decoration-none ms-3",
  style: "color: white; background-color: violet; box-shadow: 0 0 10px white, 0 0 20px white; border: 1px solid white;"
%>

<%# Lien Edit — bleu néon %>
<%= link_to "Do you want to modify something? Click here", edit_task_path(@task),
  class: "d-block mt-3 text-decoration-none",
  style: "color: #00bfff; text-shadow: 0 0 10px #00bfff, 0 0 20px #00bfff;"
%>
</div>
